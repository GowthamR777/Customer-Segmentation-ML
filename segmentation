        "# ==============================\n",
        "# 📌 STEP 1: IMPORT LIBRARIES\n",
        "# ==============================\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.cluster import KMeans, AgglomerativeClustering\n",
        "from sklearn.metrics import silhouette_score\n",
        "import scipy.cluster.hierarchy as sch\n",
        "\n",
        "# ==============================\n",
        "# 📌 STEP 2: LOAD DATASET\n",
        "# ==============================\n",
        "df = pd.read_csv(\"Mall_Customers_50k.csv\")  # Upload file in Colab first\n",
        "print(df.head())\n",
        "\n",
        "# ==============================\n",
        "# 📌 STEP 3: PREPROCESSING\n",
        "# ==============================\n",
        "# Drop CustomerID\n",
        "df = df.drop(\"CustomerID\", axis=1)\n",
        "\n",
        "# Encode Gender\n",
        "df[\"Gender\"] = df[\"Gender\"].map({\"Male\": 1, \"Female\": 0})\n",
        "\n",
        "# Scaling\n",
        "scaler = StandardScaler()\n",
        "X_scaled = scaler.fit_transform(df)\n",
        "\n",
        "# ==============================\n",
        "# 📌 STEP 4: EDA (VISUALIZATION)\n",
        "# ==============================\n",
        "plt.figure(figsize=(6,4))\n",
        "sns.histplot(df[\"Age\"], bins=20)\n",
        "plt.title(\"Age Distribution\")\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(6,4))\n",
        "sns.scatterplot(x=df[\"Annual Income (k$)\"], y=df[\"Spending Score (1-100)\"])\n",
        "plt.title(\"Income vs Spending\")\n",
        "plt.show()\n",
        "\n",
        "# ==============================\n",
        "# 📌 STEP 5: ELBOW METHOD\n",
        "# ==============================\n",
        "wcss = []\n",
        "for i in range(1,11):\n",
        "    kmeans = KMeans(n_clusters=i, random_state=42)\n",
        "    kmeans.fit(X_scaled)\n",
        "    wcss.append(kmeans.inertia_)\n",
        "\n",
        "plt.plot(range(1,11), wcss, marker='o')\n",
        "plt.title(\"Elbow Method\")\n",
        "plt.xlabel(\"Number of Clusters\")\n",
        "plt.ylabel(\"WCSS\")\n",
        "plt.show()\n",
        "\n",
        "# ==============================\n",
        "# 📌 STEP 6: K-MEANS\n",
        "# ==============================\n",
        "kmeans = KMeans(n_clusters=5, random_state=42)\n",
        "y_kmeans = kmeans.fit_predict(X_scaled)\n",
        "\n",
        "df[\"KMeans_Cluster\"] = y_kmeans\n",
        "\n",
        "# ==============================\n",
        "# 📌 STEP 7: HIERARCHICAL\n",
        "# ==============================\n",
        "plt.figure(figsize=(10,5))\n",
        "sch.dendrogram(sch.linkage(X_scaled[:1000], method='ward'))  # use subset for speed\n",
        "plt.title(\"Dendrogram\")\n",
        "plt.show()\n",
        "\n",
        "# Use smaller sample for hierarchical clustering\n",
        "X_sample = X_scaled[:2000]\n",
        "\n",
        "hc = AgglomerativeClustering(n_clusters=5)\n",
        "y_hc_sample = hc.fit_predict(X_sample)\n",
        "\n",
        "print(\"Hierarchical (sample) Score:\", silhouette_score(X_sample, y_hc_sample))\n",
        "\n",
        "# ==============================\n",
        "# 📌 STEP 8: EVALUATION\n",
        "# ==============================\n",
        "kmeans_score = silhouette_score(X_scaled, y_kmeans)\n",
        "hc_score = silhouette_score(X_sample, y_hc_sample)\n",
        "\n",
        "print(\"K-Means Silhouette Score:\", kmeans_score)\n",
        "print(\"Hierarchical Silhouette Score:\", hc_score)\n",
        "\n",
        "# ==============================\n",
        "# 📌 STEP 9: VISUALIZE CLUSTERS\n",
        "# ==============================\n",
        "plt.figure(figsize=(6,5))\n",
        "plt.scatter(df[\"Annual Income (k$)\"], df[\"Spending Score (1-100)\"], c=y_kmeans)\n",
        "plt.title(\"K-Means Clusters\")\n",
        "plt.xlabel(\"Income\")\n",
        "plt.ylabel(\"Spending Score\")\n",
        "plt.show()\n",
        "\n",
        "# ==============================\n",
